\setbeamerfont{subsection in toc}{series=\normalfont, size=\small}

\newcommand{\tamanhotitulo}[1]{%
  \setbeamerfont{title}{size=\csname #1\endcsname, series=\bfseries}%
}
\newcommand{\titlesize}[1]{\tamanhotitulo{#1}}
