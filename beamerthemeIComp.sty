% ---------------------------------------------------------------------------
%  METADADOS / LOGOS
% ---------------------------------------------------------------------------
\newcommand{\orientador}[1]{\def\icompAdvisorText{#1}}
\newcommand{\contato}[1]{\def\icompContactEmail{#1}}
\newcommand{\rodape}[1]{\def\icompFooterText{#1}}
\def\icompAdvisorText{}
\def\icompContactEmail{}
\def\icompFooterText{}
\newcommand{\advisor}[1]{\orientador{#1}}
\newcommand{\email}[1]{\contato{#1}}
\newcommand{\icompadvisor}[1]{\orientador{#1}}
\newcommand{\ufamadvisor}[1]{\orientador{#1}}
\newcommand{\icompfooter}[1]{\rodape{#1}}
\newcommand{\ufamfooter}[1]{\rodape{#1}}

\newlength{\icompLogoHeight}
\setlength{\icompLogoHeight}{0.72cm}

\newcommand{\ICompIncludeLogo}[3][\icompLogoHeight]{%
  \IfFileExists{logos/#2}{%
    \includegraphics[height=#1]{logos/#2}%
  }{%
    \IfFileExists{#2}{%
      \includegraphics[height=#1]{#2}%
    }{%
      \IfFileExists{../logos/#2}{%
        \includegraphics[height=#1]{../logos/#2}%
      }{%
        \tikz[baseline=-0.5ex]{%
          \node[fill=icompWhite, rounded corners=2pt,
                inner sep=3pt, font=\scriptsize\bfseries, text=icompTealDark]
            {\detokenize{#3}};%
        }%
      }%
    }%
  }%
}

