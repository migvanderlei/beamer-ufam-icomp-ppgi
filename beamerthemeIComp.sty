% ---------------------------------------------------------------------------
%  ASSINATURA SUPERIOR — IComp à esquerda, UFAM à direita
% ---------------------------------------------------------------------------
\newcommand{\ICompBrandBand}{%
  \begin{beamercolorbox}[%
      wd=\paperwidth,
      ht=0.78cm, dp=0pt,
      leftskip=0.72cm, rightskip=0.72cm]{headline}%
    \vspace{0.10cm}%
    \makebox[\dimexpr\paperwidth-1.44cm\relax][s]{%
      \raisebox{0pt}[0.50cm][0pt]{%
        \ICompIncludeLogo[0.48cm]{logo_icomp.png}{IComp}}%
      \hfill
      \raisebox{-0.02cm}[0.54cm][0pt]{%
        \ICompIncludeLogo[0.54cm]{logo_ufam.png}{UFAM}}%
    }%
  \end{beamercolorbox}%
  \makebox[0pt][l]{%
    \textcolor{icompTeal}{\rule{0.78\paperwidth}{1.15pt}}%
    \textcolor{icompLime}{\rule{0.22\paperwidth}{1.15pt}}}%
}

% ---------------------------------------------------------------------------
%  CABEÇALHO / TÍTULO / RODAPÉ
% ---------------------------------------------------------------------------
\setbeamertemplate{headline}{\ICompBrandBand}

\setbeamertemplate{frametitle}{%
  \nointerlineskip%
  \vspace{0.42em}%
  \begin{beamercolorbox}[%
      wd=\textwidth,
      leftskip=0pt, rightskip=0pt]{frametitle}%
    \begin{minipage}[t]{\dimexpr\textwidth\relax}
      \hbox{%
        \textcolor{icompLime}{\rule{3pt}{1.15em}}%
        \hspace{0.55em}%
        {\usebeamerfont{frametitle}\insertframetitle}}%
      \ifx\insertframesubtitle\@empty\else%
        \vspace{0.18em}%
        \hspace*{0.90em}%
        {\usebeamerfont{framesubtitle}%
         \textcolor{icompMidGray}{\insertframesubtitle}}%
      \fi%
    \end{minipage}%
  \end{beamercolorbox}%
  \vspace{0.55em}%
}

\setbeamertemplate{footline}{%
  \leavevmode
  \begin{beamercolorbox}[%
      wd=\paperwidth,
      ht=0.45cm, dp=0.32cm,
      leftskip=0.85cm,
      rightskip=0.85cm]{footline}%
    \usebeamerfont{footline}%
    \textcolor{icompMidGray}{%
      \insertshortauthor
      \expandafter\ifstrempty\expandafter{\icompFooterText}{}{%
        \hspace{0.55em}\textcolor{icompLine}{|}\hspace{0.55em}%
        \icompFooterText
      }%
    }%
    \hfill
    \textcolor{icompMidGray}{%
      \insertframenumber\,/\,\inserttotalframenumber}%
  \end{beamercolorbox}%
}

% ---------------------------------------------------------------------------
%  SLIDE DE CAPA
% ---------------------------------------------------------------------------
\setbeamertemplate{title page}{%
  \begin{tikzpicture}[remember picture, overlay]
    \fill[icompCanvas]
      (current page.south west) rectangle (current page.north east);

    \fill[icompWhite]
      (current page.north west)
      rectangle ([yshift=-1.35cm]current page.north east);
    \fill[icompTeal]
      ([yshift=-1.35cm]current page.north west)
      rectangle ([xshift=0.78\paperwidth,yshift=-1.39cm]current page.north west);
    \fill[icompLime]
      ([xshift=0.78\paperwidth,yshift=-1.35cm]current page.north west)
      rectangle ([yshift=-1.39cm]current page.north east);

    \node[anchor=west, inner sep=0pt]
      at ([xshift=0.85cm, yshift=-0.68cm]current page.north west){%
        \ICompIncludeLogo[0.78cm]{logo_icomp.png}{IComp}%
      };
    \node[anchor=east, inner sep=0pt]
      at ([xshift=-0.85cm, yshift=-0.68cm]current page.north east){%
        \ICompIncludeLogo[0.90cm]{logo_ufam.png}{UFAM}%
      };

    \fill[icompTealDark, rounded corners=10pt]
      ([xshift=0.70cm,yshift=-1.78cm]current page.north west)
      rectangle
      ([xshift=-0.70cm,yshift=0.72cm]current page.south east);

    \node[anchor=north west,
          text width=0.82\paperwidth,
          inner sep=0pt, align=left]
      at ([xshift=1.15cm, yshift=-2.15cm]current page.north west){%
        {\usebeamerfont{title}\textcolor{icompWhite}{\inserttitle}\par}%
        \vspace{0.55em}%
        {\color{icompLime}\rule{1.2cm}{2.2pt}}\par
        \vspace{0.45em}%
        {\usebeamerfont{subtitle}\textcolor{icompLime}{\insertsubtitle}\par}%
      };

    \node[anchor=south west,
          text width=0.82\paperwidth,
          inner sep=0pt, align=left]
      at ([xshift=1.15cm, yshift=0.95cm]current page.south west){%
        {\usebeamerfont{author}\textcolor{icompWhite}{\insertauthor}\par}%
        \ifstrempty{\icompAdvisorText}{}{%
          \vspace{0.28em}%
          {\fontsize{9}{11}\selectfont
           \textcolor{icompTealSoft}{\icompAdvisorText}\par}%
        }%
        \vspace{0.28em}%
        {\fontsize{8}{10}\selectfont
         \textcolor{icompTealSoft}{\insertinstitute}\par}%
        \vspace{0.40em}%
        {\usebeamerfont{date}\textcolor{icompLimeSoft}{\insertdate}\par}%
      };
  \end{tikzpicture}%
}

