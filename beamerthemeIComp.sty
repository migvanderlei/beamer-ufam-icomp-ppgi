      \begin{tikzpicture}[remember picture, overlay]
        \fill[icompCanvas]
          (current page.south west) rectangle (current page.north east);

        \fill[icompTeal]
          (current page.south west)
          rectangle ([xshift=0.30\paperwidth]current page.north west);

        \fill[icompLime]
          ([xshift=0.30\paperwidth]current page.south west)
          rectangle ([xshift=0.312\paperwidth]current page.north west);

        \node[anchor=west, inner sep=0pt]
          at ([xshift=0.42cm, yshift=-0.70cm]current page.north west){%
            \ICompIncludeLogo[0.52cm]{logo_icomp_white.png}{IComp}%
          };

        \node[anchor=east, inner sep=0pt]
          at ([xshift=-0.78cm, yshift=-0.70cm]current page.north east){%
            \ICompIncludeLogo[0.72cm]{logo_ufam.png}{UFAM}%
          };

        \node[font=\fontsize{72}{72}\selectfont\bfseries,
              text=icompWhite, opacity=0.16, anchor=center]
          at ([xshift=0.15\paperwidth]current page.west |- current page.center)
          {\two@digits{\value{section}}};

        \node[anchor=west,
              text width=0.58\paperwidth, align=left,
              text=icompTealDark,
              font=\fontsize{22}{26}\selectfont\bfseries]
          at ([xshift=0.38\paperwidth]current page.west |- current page.center)
          {\insertsectionhead};

        \fill[icompLime, rounded corners=1pt]
          ([xshift=0.38\paperwidth,yshift=-0.72cm]
            current page.west |- current page.center)
          rectangle
          ([xshift=0.38\paperwidth+1.15cm,yshift=-0.77cm]
            current page.west |- current page.center);
      \end{tikzpicture}%
      \null
    \end{frame}%
  \fi
}

% ---------------------------------------------------------------------------
%  FIGURA AMPLA — \begin{figuraampla}{Legenda} ... \end{figuraampla}
% ---------------------------------------------------------------------------
\newenvironment{figuraampla}[1]{%
  \def\icompFigureCaption{#1}%
  \begin{center}
}{%
  \end{center}
  \vspace{0.55em}%
  \noindent
  {\footnotesize\textcolor{icompDarkGray}{\icompFigureCaption}\par}%
}
\newenvironment{bigfigure}[1]{\begin{figuraampla}{#1}}{\end{figuraampla}}
\newenvironment{icompfigure}[1]{\begin{figuraampla}{#1}}{\end{figuraampla}}
\newenvironment{ufamfigure}[1]{\begin{figuraampla}{#1}}{\end{figuraampla}}

% ---------------------------------------------------------------------------
%  SLIDE FINAL — agradecimentos (sem subtítulo)
%
%    \textofinal{Obrigado!}
%    \contato{seu.email@ufam.edu.br}
%    \apoio{ \imgapoio[height=0.55cm]{logo_cnpq.png} ... }
%    \agradecimentos
% ---------------------------------------------------------------------------
\newif\ificompThanksTitleSet
\newif\ificompThanksLabelSet

\newcommand{\titulofinal}[1]{%
  \def\icompThanksTitle{#1}%
  \icompThanksTitleSettrue
}
\newcommand{\textofinal}[1]{\titulofinal{#1}}
\newcommand{\rodapefinal}[1]{\def\icompThanksFooter{#1}}
\newcommand{\rotuloapoio}[1]{%
  \def\icompThanksLogosLabel{#1}%
  \icompThanksLabelSettrue
}
\newcommand{\alturaapoio}[1]{\def\icompThanksLogoHeight{#1}}

\def\icompThanksTitle{Obrigado!}
\def\icompThanksLogosLabel{Apoio}
\def\icompThanksLogoHeight{0.55cm}
\def\icompThanksApoio{}
\def\icompThanksFooter{}
\newsavebox{\icompThanksBox}

% Babel: defaults PT-BR / EN via \languagename (não usa \iflanguage — instável com Beamer)
\newcommand{\ICompApplyBabelDefaults}{%
  \ificompThanksTitleSet\else
    \ifdefstring{\languagename}{english}{%
      \def\icompThanksTitle{Thank you!}%
    }{%
      \def\icompThanksTitle{Obrigado!}%
    }%
  \fi
  \ificompThanksLabelSet\else
    \ifdefstring{\languagename}{english}{%
      \def\icompThanksLogosLabel{Support}%
    }{%
      \def\icompThanksLogosLabel{Apoio}%
    }%
  \fi
}
\AtBeginDocument{\ICompApplyBabelDefaults}

\newcommand{\ICompGraphic}[2][]{%
  \IfFileExists{logos/#2}{%
    \includegraphics[#1]{logos/#2}%
  }{%
    \IfFileExists{#2}{%
      \includegraphics[#1]{#2}%
    }{%
      \IfFileExists{../logos/#2}{%
        \includegraphics[#1]{../logos/#2}%
      }{%
        \tikz[baseline=-0.5ex]{%
          \node[fill=icompWhite, rounded corners=2pt,
                inner sep=3pt, font=\scriptsize\bfseries, text=icompTealDark]
            {\detokenize{#2}};%
        }%
      }%
    }%
  }%
}

% \imgapoio[height=...]{arquivo} — default = \alturaapoio
\newcommand{\imgapoio}{%
  \@ifnextchar[\icomp@imgapoio@opt{\icomp@imgapoio@opt[height=\icompThanksLogoHeight]}%
}
\def\icomp@imgapoio@opt[#1]#2{%
  \raisebox{-0.5\height}{\ICompGraphic[#1]{#2}}%
  \hspace{1.15em}%
}

\newcommand{\apoio}[1]{\def\icompThanksApoio{#1}}

\newcommand{\ICompRenderThanksLogos}{%
  \expandafter\ifstrempty\expandafter{\icompThanksApoio}{%
  }{%
    {\footnotesize\textcolor{icompMidGray}{\icompThanksLogosLabel}\par}%
    \vspace{0.45em}%
    \mbox{\icompThanksApoio}%
    \par\vspace{0.65em}%
  }%
}

\newcommand{\ICompRenderThanksFooter}{%
  \expandafter\ifstrempty\expandafter{\icompThanksFooter}{%
    {\small\color{icompMidGray}\insertauthor}%
    \expandafter\ifstrempty\expandafter{\icompContactEmail}{}{%
      \\[5pt]%
      {\footnotesize\color{icompTeal}%
        \href{mailto:\icompContactEmail}{\texttt{\icompContactEmail}}}%
    }%
  }{%
    {\small\color{icompMidGray}\icompThanksFooter}%
  }%
}

\newcommand{\agradecimentos}{%
  \@ifnextchar[\icomp@agradecimentos@opt\icomp@agradecimentos@go
}
\def\icomp@agradecimentos@opt[#1]{%
  \def\icompThanksTitle{#1}%
  \icompThanksTitleSettrue
  \icomp@agradecimentos@go
}
\def\icomp@agradecimentos@go{%
  \begin{lrbox}{\icompThanksBox}%
    \begin{minipage}{0.55\paperwidth}%
      \raggedright
      \ICompRenderThanksLogos
      \ICompRenderThanksFooter
    \end{minipage}%
  \end{lrbox}%
  \begin{frame}[noframenumbering, plain]
    \begin{tikzpicture}[remember picture, overlay]
      \fill[icompCanvas]
        (current page.south west) rectangle (current page.north east);

      \fill[icompTeal]
        ([xshift=0.68\paperwidth]current page.south west)
        rectangle (current page.north east);

      \fill[icompLime]
        ([xshift=0.665\paperwidth]current page.south west)
        rectangle ([xshift=0.68\paperwidth]current page.north west);

      \node[anchor=west, inner sep=0pt]
        at ([xshift=0.90cm, yshift=-0.78cm]current page.north west){%
          \ICompIncludeLogo[0.72cm]{logo_icomp.png}{IComp}%
        };

      \node[anchor=center, inner sep=0pt]
        at ([xshift=-0.16\paperwidth]current page.east |- current page.center){%
          \ICompIncludeLogo[3.6cm]{logo_ufam_white.png}{UFAM}%
        };

      \node[anchor=west, font=\fontsize{26}{30}\selectfont\bfseries,
            text=icompTealDark]
        at ([xshift=1.05cm,yshift=0.35cm]current page.west |- current page.center)
        {\icompThanksTitle};

      \fill[icompLime, rounded corners=1pt]
        ([xshift=1.05cm,yshift=-0.28cm]current page.west |- current page.center)
        rectangle
        ([xshift=2.30cm,yshift=-0.33cm]current page.west |- current page.center);

      \node[anchor=south west, inner sep=0pt]
        at ([xshift=1.05cm,yshift=0.55cm]current page.south west)
        {\usebox{\icompThanksBox}};
    \end{tikzpicture}%
    \null
  \end{frame}%
}

