\setbeamercolor{palette tertiary}{fg=icompWhite, bg=icompTealDark}
\setbeamercolor{palette quaternary}{fg=icompTealDark, bg=icompCanvas}

\setbeamercolor{frametitle}{fg=icompTealDark, bg=icompWhite}
\setbeamercolor{framesubtitle}{fg=icompTeal}

\setbeamercolor{title}{fg=icompTealDark, bg=icompWhite}
\setbeamercolor{subtitle}{fg=icompTeal}
\setbeamercolor{author}{fg=icompText}
\setbeamercolor{institute}{fg=icompMidGray}
\setbeamercolor{date}{fg=icompMidGray}

\setbeamercolor{block title}{fg=icompTealDark, bg=icompTealSoft}
