% =============================================================================
%  beamerthemeUFAM.sty
%  Tema Beamer — Instituto de Computação (IComp) / PPGI / UFAM
%
%  Design anchor: logos/logo_icomp.png + logos/logo_ufam.png (marcas oficiais)
%  logos/logo_ufam_white.png — variante branca p/ fundos escuros (teal), sem caixa branca
%  Hex amostrados do PNG IComp (não do MIV-UFAM genérico):
%    icompLime  #A8C840  — folha (acento primário)
%    icompTeal  #286880  — wordmark (cor estrutural)
%
%  Identidade IComp + UFAM: tipografia + whitespace; lima destaca, teal estrutura.
%  Sem desenhos TikZ customizados — só logos oficiais e formas geométricas simples.
%  Compatível com: pdflatex / lualatex / xelatex + Overleaf
% =============================================================================

\ProvidesPackage{beamerthemeUFAM}[2026/07/10 v2.0 IComp/UFAM Beamer Theme]

\mode<presentation>

% ---------------------------------------------------------------------------
%  DEPENDÊNCIAS
% ---------------------------------------------------------------------------
\RequirePackage{tikz}
\RequirePackage{xcolor}
\RequirePackage[T1]{fontenc}
\RequirePackage{graphicx}
\RequirePackage{ifthen}
\RequirePackage{etoolbox}
\RequirePackage[scaled=0.92]{helvet}
\renewcommand{\familydefault}{\sfdefault}
\usetikzlibrary{calc, positioning, shapes.geometric, backgrounds, arrows.meta}

% ---------------------------------------------------------------------------
%  PALETA — amostrada do logo IComp (folha + circuito)
%  CHANGED (v2.0): dropped MIV-UFAM navy/green-heavy scheme. Teal-blue is now
%  the dominant structural color; lime green is the sole primary accent.
% ---------------------------------------------------------------------------
\definecolor{icompLime}{HTML}{A8C840}       % folha do logo (amostra PNG)
\definecolor{icompLimeDark}{HTML}{789426}   % lima escurecida (texto sobre soft)
\definecolor{icompLimeSoft}{HTML}{F2F6E8}   % fundo de destaque lima
\definecolor{icompTeal}{HTML}{286880}       % wordmark / circuito (amostra PNG)
\definecolor{icompTealDark}{HTML}{1D5366}   % teal profundo (títulos / painéis)
\definecolor{icompTealSoft}{HTML}{EAF2F4}   % fundo estrutural suave
\definecolor{icompTealMid}{HTML}{508098}    % gradiente claro do wordmark
\definecolor{icompRed}{HTML}{C94B4B}        % alerta (neutro, fora da marca)
\definecolor{icompRedSoft}{HTML}{F9EEEE}
\definecolor{icompWhite}{HTML}{FFFFFF}
\definecolor{icompCanvas}{HTML}{F7F9F8}     % fundo de página (quase branco)
\definecolor{icompLine}{HTML}{DDE5E4}
\definecolor{icompMidGray}{HTML}{74858B}
\definecolor{icompDarkGray}{HTML}{405259}
\definecolor{icompText}{HTML}{17282E}

% Aliases legados ufam* → paleta IComp (main.tex / slides antigos)
\colorlet{ufamGreen}{icompLime}
\colorlet{ufamGreenDark}{icompLimeDark}
\colorlet{ufamGreenLight}{icompLimeSoft}
\colorlet{ufamGreenSoft}{icompLimeSoft}
\colorlet{ufamLime}{icompLime}
\colorlet{ufamLimeGreen}{icompLime}
\colorlet{ufamYellowGreen}{icompLime}
\colorlet{ufamTeal}{icompTeal}
\colorlet{ufamTealLight}{icompTealSoft}
\colorlet{ufamTealSoft}{icompTealSoft}
\colorlet{ufamTealUnit}{icompTeal}
% CHANGED (v2.0): ufamNavy agora aponta para teal estrutural (não #0D3049)
\colorlet{ufamNavy}{icompTealDark}
\colorlet{ufamNavyLight}{icompTealMid}
\colorlet{ufamNavySoft}{icompTealMid}
\colorlet{ufamNavyUnit}{icompTealDark}
\colorlet{ufamRed}{icompRed}
\colorlet{ufamWhite}{icompWhite}
\colorlet{ufamCanvas}{icompCanvas}
\colorlet{ufamLightGray}{icompCanvas}
\colorlet{ufamLine}{icompLine}
\colorlet{ufamMidGray}{icompMidGray}
\colorlet{ufamDarkGray}{icompDarkGray}
\colorlet{ufamText}{icompText}
\colorlet{ufamTextDark}{icompText}
\colorlet{ufamBlack}{icompText}
\colorlet{ufamPink}{icompRed}
\colorlet{ufamYellow}{icompLime}
\colorlet{ufamOrange}{icompRed}
\colorlet{ufamGold}{icompLime}
\colorlet{ufamAmber}{icompLime}
\colorlet{ufamPurple}{icompTealDark}
\colorlet{ufamPurplePPG}{icompTealDark}
\colorlet{ufamFuchsia}{icompRed}

% ---------------------------------------------------------------------------
%  METADADOS / LOGOS
% ---------------------------------------------------------------------------
\newcommand{\icompadvisor}[1]{\def\icompAdvisorText{#1}}
\newcommand{\icompfooter}[1]{\def\icompFooterText{#1}}
\def\icompAdvisorText{}
\def\icompFooterText{IComp — UFAM}
\newcommand{\ufamadvisor}[1]{\icompadvisor{#1}}
\newcommand{\ufamfooter}[1]{\icompfooter{#1}}

\newlength{\icompLogoHeight}
\setlength{\icompLogoHeight}{0.72cm}

% Resolve logos/…, raiz, ou ../logos/ (Overleaf / clones)
\newcommand{\ICompIncludeLogo}[3][\icompLogoHeight]{%
  \IfFileExists{logos/#2}{%
    \includegraphics[height=#1]{logos/#2}%
  }{%
    \IfFileExists{#2}{%
      \includegraphics[height=#1]{#2}%
    }{%
      \IfFileExists{../logos/#2}{%
        \includegraphics[height=#1]{../logos/#2}%
      }{%
        \tikz[baseline=-0.5ex]{%
          \node[fill=icompWhite, rounded corners=2pt,
                inner sep=3pt, font=\scriptsize\bfseries, text=icompTealDark]
            {#3};%
        }%
      }%
    }%
  }%
}

% ---------------------------------------------------------------------------
%  FONTES
% ---------------------------------------------------------------------------
\usefonttheme{professionalfonts}
\usefonttheme[onlymath]{serif}

% ---------------------------------------------------------------------------
%  CORES DO BEAMER
%  CHANGED (v2.0): teal for structure; lime only for accents / highlights.
% ---------------------------------------------------------------------------
\usecolortheme{default}

\setbeamercolor{structure}{fg=icompTeal}
\setbeamercolor{normal text}{fg=icompText, bg=icompWhite}
\setbeamercolor{alerted text}{fg=icompRed}
\setbeamercolor{example text}{fg=icompLimeDark}

\setbeamercolor{palette primary}{fg=icompWhite, bg=icompTeal}
\setbeamercolor{palette secondary}{fg=icompTealDark, bg=icompLime}
\setbeamercolor{palette tertiary}{fg=icompWhite, bg=icompTealDark}
\setbeamercolor{palette quaternary}{fg=icompTealDark, bg=icompCanvas}

\setbeamercolor{frametitle}{fg=icompTealDark, bg=icompWhite}
\setbeamercolor{framesubtitle}{fg=icompTeal}

\setbeamercolor{title}{fg=icompTealDark, bg=icompWhite}
\setbeamercolor{subtitle}{fg=icompTeal}
\setbeamercolor{author}{fg=icompText}
\setbeamercolor{institute}{fg=icompMidGray}
\setbeamercolor{date}{fg=icompMidGray}

\setbeamercolor{block title}{fg=icompTealDark, bg=icompTealSoft}
\setbeamercolor{block body}{fg=icompText, bg=icompTealSoft}
\setbeamercolor{block title alerted}{fg=icompRed, bg=icompRedSoft}
\setbeamercolor{block body alerted}{fg=icompText, bg=icompRedSoft}
\setbeamercolor{block title example}{fg=icompLimeDark, bg=icompLimeSoft}
\setbeamercolor{block body example}{fg=icompText, bg=icompLimeSoft}

\setbeamercolor{item}{fg=icompLime}
\setbeamercolor{subitem}{fg=icompTeal}
\setbeamercolor{subsubitem}{fg=icompDarkGray}

\setbeamercolor{footline}{fg=icompDarkGray, bg=icompWhite}
\setbeamercolor{headline}{fg=icompTealDark, bg=icompWhite}
\setbeamercolor{separation line}{bg=icompLime}

\setbeamercolor{section in toc}{fg=icompTealDark}
\setbeamercolor{subsection in toc}{fg=icompTeal}
\setbeamercolor{section in toc shaded}{fg=icompMidGray}

% ---------------------------------------------------------------------------
%  TIPOGRAFIA
%  CHANGED (v2.0): slightly smaller default title for long PT dissertations;
%  hierarchy via weight/size, not color blocks. \icomptitlesize / \ufamtitlesize
%  toggle manually when needed.
% ---------------------------------------------------------------------------
\setbeamerfont{title}{size=\fontsize{16}{19}\selectfont, series=\bfseries}
\setbeamerfont{subtitle}{size=\normalsize, series=\normalfont}
\setbeamerfont{author}{size=\normalsize, series=\bfseries}
\setbeamerfont{institute}{size=\small, series=\normalfont}
\setbeamerfont{date}{size=\footnotesize}
\setbeamerfont{frametitle}{size=\fontsize{14.5}{17.5}\selectfont, series=\bfseries}
\setbeamerfont{framesubtitle}{size=\footnotesize, series=\normalfont}
\setbeamerfont{block title}{size=\normalsize, series=\bfseries}
\setbeamerfont{footline}{size=\fontsize{6.5}{8}\selectfont}
\setbeamerfont{section in toc}{series=\bfseries, size=\normalsize}
\setbeamerfont{subsection in toc}{series=\normalfont, size=\small}

\newcommand{\icomptitlesize}[1]{%
  \setbeamerfont{title}{size=\csname #1\endcsname, series=\bfseries}%
}
\newcommand{\ufamtitlesize}[1]{\icomptitlesize{#1}}

% ---------------------------------------------------------------------------
%  ASSINATURA SUPERIOR — IComp à esquerda, brasão UFAM à direita
%  CHANGED (v2.1): restore official UFAM logo; no custom drawn motifs.
% ---------------------------------------------------------------------------
\newcommand{\ICompBrandBand}{%
  \begin{beamercolorbox}[%
      wd=\paperwidth,
      ht=0.78cm, dp=0pt,
      leftskip=0.72cm, rightskip=0.72cm]{headline}%
    \vspace{0.10cm}%
    \makebox[\dimexpr\paperwidth-1.44cm\relax][s]{%
      \raisebox{0pt}[0.50cm][0pt]{%
        \ICompIncludeLogo[0.48cm]{logo_icomp.png}{IComp}}%
      \hfill
      \raisebox{-0.02cm}[0.54cm][0pt]{%
        \ICompIncludeLogo[0.54cm]{logo_ufam.png}{UFAM}}%
    }%
  \end{beamercolorbox}%
  \makebox[0pt][l]{%
    \textcolor{icompTeal}{\rule{0.78\paperwidth}{1.15pt}}%
    \textcolor{icompLime}{\rule{0.22\paperwidth}{1.15pt}}}%
}

% ---------------------------------------------------------------------------
%  CABEÇALHO / TÍTULO DO FRAME
%  CHANGED (v2.0): no fixed ht/dp — colorbox sizes to content so two-line
%  frametitles never clip. Lime rule = accent; title weight does the hierarchy.
% ---------------------------------------------------------------------------
\setbeamertemplate{headline}{\ICompBrandBand}

\setbeamertemplate{frametitle}{%
  \nointerlineskip%
  \vspace{0.42em}%
  \begin{beamercolorbox}[%
      wd=\textwidth,
      leftskip=0pt, rightskip=0pt]{frametitle}%
    \begin{minipage}[t]{\dimexpr\textwidth\relax}
      \hbox{%
        \textcolor{icompLime}{\rule{3pt}{1.15em}}%
        \hspace{0.55em}%
        {\usebeamerfont{frametitle}\insertframetitle}}%
      \ifx\insertframesubtitle\@empty\else%
        \vspace{0.18em}%
        \hspace*{0.90em}%
        {\usebeamerfont{framesubtitle}%
         \textcolor{icompMidGray}{\insertframesubtitle}}%
      \fi%
    \end{minipage}%
  \end{beamercolorbox}%
  \vspace{0.55em}%
}

% ---------------------------------------------------------------------------
%  SLIDE DE CAPA
%  CHANGED (v2.2): single vertical stack inside the teal panel —
%    title → subtitle → author → advisor → date.
%  Dropped multi-line \insertinstitute from the cover (logos already brand
%  IComp/UFAM; those lines read as chrome/header-footer). Date sits with the
%  people block, not floating in the corner. Advisor via \icompadvisor{...}.
% ---------------------------------------------------------------------------
\setbeamertemplate{title page}{%
  \begin{tikzpicture}[remember picture, overlay]
    \fill[icompCanvas]
      (current page.south west) rectangle (current page.north east);

    %% faixa branca + linha estrutural teal/lima
    \fill[icompWhite]
      (current page.north west)
      rectangle ([yshift=-1.35cm]current page.north east);
    \fill[icompTeal]
      ([yshift=-1.35cm]current page.north west)
      rectangle ([xshift=0.78\paperwidth,yshift=-1.39cm]current page.north west);
    \fill[icompLime]
      ([xshift=0.78\paperwidth,yshift=-1.35cm]current page.north west)
      rectangle ([yshift=-1.39cm]current page.north east);

    %% logos oficiais: IComp (esq.) + UFAM (dir.)
    \node[anchor=west, inner sep=0pt]
      at ([xshift=0.85cm, yshift=-0.68cm]current page.north west){%
        \ICompIncludeLogo[0.78cm]{logo_icomp.png}{IComp}%
      };
    \node[anchor=east, inner sep=0pt]
      at ([xshift=-0.85cm, yshift=-0.68cm]current page.north east){%
        \ICompIncludeLogo[0.90cm]{logo_ufam.png}{UFAM}%
      };

    %% painel de conteúdo
    \fill[icompTealDark, rounded corners=10pt]
      ([xshift=0.70cm,yshift=-1.78cm]current page.north west)
      rectangle
      ([xshift=-0.70cm,yshift=0.72cm]current page.south east);

    %% topo do painel: título + subtítulo (instituto fica nos logos)
    \node[anchor=north west,
          text width=0.82\paperwidth,
          inner sep=0pt, align=left]
      at ([xshift=1.15cm, yshift=-2.15cm]current page.north west){%
        {\usebeamerfont{title}\textcolor{icompWhite}{\inserttitle}\par}%
        \vspace{0.55em}%
        {\color{icompLime}\rule{1.2cm}{2.2pt}}\par
        \vspace{0.45em}%
        {\usebeamerfont{subtitle}\textcolor{icompLime}{\insertsubtitle}\par}%
      };

    %% base do painel: autor → orientador(a) → data (um bloco só, sem flutuação)
    \node[anchor=south west,
          text width=0.82\paperwidth,
          inner sep=0pt, align=left]
      at ([xshift=1.15cm, yshift=1.05cm]current page.south west){%
        {\usebeamerfont{author}\textcolor{icompWhite}{\insertauthor}\par}%
        \ifstrempty{\icompAdvisorText}{}{%
          \vspace{0.32em}%
          {\fontsize{9}{11}\selectfont
           \textcolor{icompTealSoft}{\icompAdvisorText}\par}%
        }%
        \vspace{0.48em}%
        {\usebeamerfont{date}\textcolor{icompLimeSoft}{\insertdate}\par}%
      };
  \end{tikzpicture}%
}

% ---------------------------------------------------------------------------
%  RODAPÉ
%  CHANGED (v2.0): max 2 fields on the left (shortauthor | footer label) plus
%  a width-capped page number on the right — no shorttitle+author+institute jam.
% ---------------------------------------------------------------------------
\setbeamertemplate{footline}{%
  \leavevmode%
  \makebox[0pt][l]{%
    \textcolor{icompTeal}{\rule{0.78\paperwidth}{0.5pt}}%
    \textcolor{icompLime}{\rule{0.22\paperwidth}{0.5pt}}}%
  \begin{beamercolorbox}[%
      wd=\paperwidth,
      ht=0.42cm, dp=0.12cm,
      leftskip=0.72cm, rightskip=0.72cm]{footline}%
    \begin{minipage}[c]{0.72\paperwidth}
      \raggedright
      \usebeamerfont{footline}%
      \ifx\insertshortauthor\@empty\else
        \textcolor{icompTeal}{\textbf{\insertshortauthor}}%
        \textcolor{icompLine}{\enspace|\enspace}%
      \fi
      \ifstrempty{\icompFooterText}{%
        \textcolor{icompMidGray}{IComp — UFAM}%
      }{%
        \textcolor{icompMidGray}{\icompFooterText}%
      }%
    \end{minipage}%
    \hfill
    \begin{minipage}[c]{0.16\paperwidth}
      \raggedleft
      {\fontsize{7.5}{9}\selectfont\bfseries
       \textcolor{icompTealDark}{\insertframenumber}%
       \textcolor{icompLime}{\,/\,}%
       \textcolor{icompMidGray}{\inserttotalframenumber}}%
    \end{minipage}%
  \end{beamercolorbox}%
}

% ---------------------------------------------------------------------------
%  ITENS — círculos simples (sem glifos customizados tipo circuito)
% ---------------------------------------------------------------------------
\setbeamertemplate{itemize item}{%
  \tikz[baseline=-0.55ex]
    \fill[icompLime] (0,0) circle (0.11em);%
}
\setbeamertemplate{itemize subitem}{%
  \tikz[baseline=-0.55ex]
    \fill[icompTeal] (0,0) circle (0.09em);%
}
\setbeamertemplate{itemize subsubitem}{%
  \tikz[baseline=-0.55ex]
    \fill[icompMidGray] (0,0) circle (0.07em);%
}
\setbeamertemplate{enumerate item}{%
  \tikz[baseline=-0.55ex]{%
    \node[fill=icompTeal, text=icompWhite,
          circle, inner sep=0pt, minimum size=1.25em,
          font=\fontsize{6}{7}\selectfont\bfseries]
      {\insertenumlabel};%
  }%
}
\setbeamertemplate{enumerate subitem}{%
  \tikz[baseline=-0.55ex]{%
    \node[fill=icompTealMid, text=icompWhite,
          circle, inner sep=0pt, minimum size=1.15em,
          font=\fontsize{6}{7}\selectfont\bfseries]
      {\insertenumlabel};%
  }%
}

\AtBeginEnvironment{itemize}{%
  \setlength{\itemsep}{0.55em}%
  \setlength{\parsep}{0.20em}%
  \setlength{\topsep}{0.35em}%
}
\AtBeginEnvironment{enumerate}{%
  \setlength{\itemsep}{0.55em}%
  \setlength{\parsep}{0.20em}%
  \setlength{\topsep}{0.35em}%
}

% ---------------------------------------------------------------------------
%  BLOCOS
% ---------------------------------------------------------------------------
\setbeamertemplate{blocks}[rounded][shadow=false]

\setbeamertemplate{block begin}{%
  \par\vskip0.38em%
  \begin{beamercolorbox}[%
      wd=\linewidth, sep=0.42em,
      leftskip=0.45em, rightskip=0.3em,
      rounded=true]{block title}%
    \hbox{%
      \textcolor{icompTeal}{\rule{2.4pt}{0.95em}}%
      \hspace{0.5em}%
      \usebeamerfont*{block title}\insertblocktitle}%
  \end{beamercolorbox}%
  {\ifbeamercolorempty[bg]{block body}{}{\nointerlineskip}}%
  \begin{beamercolorbox}[%
      wd=\linewidth, sep=0.52em,
      leftskip=0.45em, rightskip=0.3em,
      rounded=true, vmode]{block body}%
}
\setbeamertemplate{block end}{\end{beamercolorbox}\vskip0.32em}

\setbeamertemplate{block alerted begin}{%
  \par\vskip0.38em%
  \begin{beamercolorbox}[%
      wd=\linewidth, sep=0.42em,
      leftskip=0.45em, rightskip=0.3em,
      rounded=true]{block title alerted}%
    \hbox{%
      \textcolor{icompRed}{\rule{2.4pt}{0.95em}}%
      \hspace{0.5em}%
      \usebeamerfont*{block title}\insertblocktitle}%
  \end{beamercolorbox}%
  {\ifbeamercolorempty[bg]{block body alerted}{}{\nointerlineskip}}%
  \begin{beamercolorbox}[%
      wd=\linewidth, sep=0.52em,
      leftskip=0.45em, rightskip=0.3em,
      rounded=true, vmode]{block body alerted}%
}
\setbeamertemplate{block alerted end}{\end{beamercolorbox}\vskip0.32em}

\setbeamertemplate{block example begin}{%
  \par\vskip0.38em%
  \begin{beamercolorbox}[%
      wd=\linewidth, sep=0.42em,
      leftskip=0.45em, rightskip=0.3em,
      rounded=true]{block title example}%
    \hbox{%
      \textcolor{icompLime}{\rule{2.4pt}{0.95em}}%
      \hspace{0.5em}%
      \usebeamerfont*{block title}\insertblocktitle}%
  \end{beamercolorbox}%
  {\ifbeamercolorempty[bg]{block body example}{}{\nointerlineskip}}%
  \begin{beamercolorbox}[%
      wd=\linewidth, sep=0.52em,
      leftskip=0.45em, rightskip=0.3em,
      rounded=true, vmode]{block body example}%
}
\setbeamertemplate{block example end}{\end{beamercolorbox}\vskip0.32em}

% ---------------------------------------------------------------------------
%  SUMÁRIO
% ---------------------------------------------------------------------------
\setbeamertemplate{section in toc}{%
  \leavevmode%
  \vskip0.45em%
  \tikz[baseline=-0.5ex]{%
    \node[fill=icompTeal, text=icompWhite,
          circle, inner sep=0pt, minimum size=1.35em,
          font=\fontsize{6.5}{7}\selectfont\bfseries]
      {\inserttocsectionnumber};%
  }%
  \hspace{0.5em}%
  {\usebeamerfont{section in toc}\inserttocsection}\par%
}
\setbeamertemplate{subsection in toc}{%
  \leavevmode\leftskip=1.55em%
  \vskip0.25em%
  \tikz[baseline=-0.5ex]
    \fill[icompLime] (0,0) circle (0.32ex);%
  \hspace{0.4em}%
  {\usebeamerfont{subsection in toc}\inserttocsubsection}\par%
}

% ---------------------------------------------------------------------------
%  SLIDE DIVISOR DE SEÇÃO
%  CHANGED (v2.1): official IComp + UFAM logos; no custom circuit drawings.
% ---------------------------------------------------------------------------
\AtBeginSection[]{%
  \begin{frame}[noframenumbering, plain]%
    \begin{tikzpicture}[remember picture, overlay]
      \fill[icompCanvas]
        (current page.south west) rectangle (current page.north east);

      \fill[icompTeal]
        (current page.south west)
        rectangle ([xshift=0.30\paperwidth]current page.north west);

      \fill[icompLime]
        ([xshift=0.30\paperwidth]current page.south west)
        rectangle ([xshift=0.312\paperwidth]current page.north west);

      % IComp on white badge (dark wordmark needs contrast on teal)
      \node[anchor=west, inner sep=0pt]
        at ([xshift=0.42cm, yshift=-0.70cm]current page.north west){%
          \tikz[baseline=(b.base)]{%
            \node[fill=icompWhite, rounded corners=5pt,
                  inner xsep=5pt, inner ysep=2.5pt, anchor=base] (b)
              {\ICompIncludeLogo[0.48cm]{logo_icomp.png}{IComp}};%
          }%
        };

      % Brasão UFAM — canto superior direito
      \node[anchor=east, inner sep=0pt]
        at ([xshift=-0.78cm, yshift=-0.70cm]current page.north east){%
          \ICompIncludeLogo[0.72cm]{logo_ufam.png}{UFAM}%
        };

      \node[font=\fontsize{72}{72}\selectfont\bfseries,
            text=icompWhite, opacity=0.16, anchor=center]
        at ([xshift=0.15\paperwidth]current page.west |- current page.center)
        {0\thesection};

      \node[anchor=west,
            text width=0.58\paperwidth, align=left,
            text=icompTealDark,
            font=\fontsize{22}{26}\selectfont\bfseries]
        at ([xshift=0.38\paperwidth]current page.west |- current page.center)
        {\insertsectionhead};

      \fill[icompLime, rounded corners=1pt]
        ([xshift=0.38\paperwidth,yshift=-0.72cm]
          current page.west |- current page.center)
        rectangle
        ([xshift=0.38\paperwidth+1.15cm,yshift=-0.77cm]
          current page.west |- current page.center);

      \node[anchor=west, text=icompMidGray,
            font=\fontsize{8}{9}\selectfont\bfseries]
        at ([xshift=0.38\paperwidth,yshift=-1.10cm]
            current page.west |- current page.center)
        {IComp — UFAM};
    \end{tikzpicture}%
  \end{frame}%
}

% ---------------------------------------------------------------------------
%  SLIDE FULL-BLEED (figuras / plots) — barra de legenda fina
%  CHANGED (v2.3): more reliable layout (no fragile negative vspace + minipage
%  height that left plots tiny / mis-centered). Use inside a plain frame:
%    \begin{frame}[plain]
%      \begin{icompfigure}{Legenda curta}
%        \includegraphics[width=0.92\paperwidth,height=0.72\paperheight,keepaspectratio]{fig}
%      \end{icompfigure}
%    \end{frame}
%  Compile twice (remember picture).
% ---------------------------------------------------------------------------
\newlength{\icompFigureBodyHt}
\newenvironment{icompfigure}[1]{%
  \def\icompFigureCaption{#1}%
  \setlength{\icompFigureBodyHt}{\dimexpr\paperheight-1.55cm\relax}%
  \begin{tikzpicture}[remember picture, overlay]
    \fill[icompWhite]
      (current page.south west) rectangle (current page.north east);
    \fill[icompTealDark]
      (current page.south west)
      rectangle ([yshift=0.78cm]current page.south east);
    \fill[icompLime]
      (current page.south west)
      rectangle ([xshift=0.18cm,yshift=0.78cm]current page.south west);
    \node[anchor=west, text=icompWhite,
          font=\footnotesize\sffamily,
          text width=0.90\paperwidth]
      at ([xshift=0.55cm, yshift=0.39cm]current page.south west)
      {\icompFigureCaption};
  \end{tikzpicture}%
  \vspace*{0.15cm}%
  \noindent
  \begin{minipage}[c][\icompFigureBodyHt][c]{\textwidth}
    \centering
}{%
  \end{minipage}%
}
\newenvironment{ufamfigure}[1]{%
  \begin{icompfigure}{#1}%
}{%
  \end{icompfigure}%
}

